# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://student360_app:PASSWORD@localhost:5432/student360"

# ── NextAuth / SSO ────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# SAML provider (NCF identity provider — Microsoft Entra / Okta / etc.)
SAML_ENTRY_POINT="https://login.microsoftonline.com/TENANT_ID/saml2"
SAML_ISSUER="https://student360.ncf.edu"
SAML_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# OR for OIDC:
OIDC_CLIENT_ID="your-client-id"
OIDC_CLIENT_SECRET="your-client-secret"
OIDC_ISSUER="https://login.microsoftonline.com/TENANT_ID/v2.0"

# In development, you can use the credentials provider — leave OIDC_* blank.
DEV_AUTH_ENABLED="true"

# ── Source System APIs ────────────────────────────────────────────────
# Banner / Ellucian Ethos
ETHOS_API_KEY="your-ethos-api-key"
ETHOS_BASE_URL="https://integrate.elluciancloud.com"

# DegreeWorks (if separate from Ethos)
DEGREEWORKS_API_URL="https://your-institution.degreeworks.com/api"
DEGREEWORKS_API_KEY="your-degreeworks-key"

# Navigate 360 (EAB)
NAVIGATE_API_URL="https://api.eab.com/navigate/v1"
NAVIGATE_API_KEY="your-navigate-api-key"
NAVIGATE_INSTITUTION_ID="ncf-institution-id"

# Knack — Tutoring application
KNACK_TUTORING_APP_ID="your-knack-app-id"
KNACK_TUTORING_API_KEY="your-knack-api-key"
KNACK_TUTORING_OBJECT_SESSIONS="object_1"
KNACK_TUTORING_OBJECT_STUDENTS="object_2"

# Knack — SSC application
KNACK_SSC_APP_ID="your-knack-ssc-app-id"
KNACK_SSC_API_KEY="your-knack-ssc-api-key"
KNACK_SSC_OBJECT_VISITS="object_3"

# NCF Evaluations System (homegrown)
EVALUATIONS_DB_URL="postgresql://readonly_user:PASSWORD@eval-db-host:5432/evaluations"
EVALUATIONS_API_URL="http://evaluations.ncf.internal/api"
EVALUATIONS_API_KEY="your-eval-api-key"

# ── Anthropic (predictive layer) ─────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── Sync config ───────────────────────────────────────────────────────
SYNC_CRON_SCHEDULE="0 2 * * *"
SYNC_SECRET="internal-sync-trigger-secret"

# ── App config ────────────────────────────────────────────────────────
APP_ENV="development"
AUDIT_LOG_RETENTION_DAYS="1825"
BRIGHT_FUTURES_ACADEMIC_GPA="3.0"
BRIGHT_FUTURES_MEDALLION_GPA="2.75"
BRIGHT_FUTURES_GOLD_GPA="2.0"
